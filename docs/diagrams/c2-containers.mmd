%% C4 Container (L2) — inside the Networthy system boundary
graph TB
    subgraph users[" "]
        admin["Household admin"]
        member["Household member"]
    end

    subgraph networthy["Networthy system"]
        spa["Domain UI<br/>(container: React SPA)<br/>@plenipo/ui app shell,<br/>Networthy-branded"]
        adminui["Admin console<br/>(container: React SPA)<br/>@plenipo/admin-ui, served at /admin"]
        host["Networthy.Host<br/>(container: ASP.NET Core)<br/>Plenipo platform + Networthy.Finance module<br/>REST reads + manual-CRUD writes,<br/>AG-UI/SignalR chat"]
        db[("Postgres<br/>(container: database)<br/>plenipo-platform + plenipo-audit")]
        redis[("Redis<br/>(container: cache)<br/>SignalR backplane,<br/>rate-limit windows")]
        blob[("Azure Blob Storage<br/>(container: file store)<br/>statement uploads,<br/>generated documents")]
    end

    apphost["Networthy.AppHost<br/>(dev-only: Aspire orchestration)"]

    plaid["Plaid"]
    ai["AI Provider"]
    ocr["Azure Document Intelligence"]
    smtp["SMTP relay"]

    admin -->|HTTPS| spa
    admin -->|HTTPS| adminui
    member -->|HTTPS| spa

    spa -->|/api/*, same origin| host
    spa -->|SignalR / AG-UI| host
    adminui -->|/api/admin/*| host

    host --> db
    host --> redis
    host --> blob
    host -->|Link, Transactions API<br/>(pull-only — no inbound<br/>webhook yet)| plaid
    host -->|categorization,<br/>chat completions| ai
    host -->|scanned-statement OCR| ocr
    host -->|budget recaps| smtp

    apphost -.->|orchestrates locally, dev only| host
    apphost -.-> db
    apphost -.-> redis
    apphost -.-> spa
    apphost -.-> adminui
