<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!-- Cortex platform packages, packed locally until they publish to GitHub Packages. -->
    <add key="cortex-local" value=".packages" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <!-- Prevent dependency-confusion fallback: product/platform packages must come from the
       vendored feed, while public dependencies resolve from nuget.org. -->
  <packageSourceMapping>
    <packageSource key="cortex-local">
      <package pattern="Cortex.*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
