<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <!-- Plenipo platform packages, vendored from the GitHub Release: they publish only to the
         GitHub Packages feed, which needs a PAT even for public repos. -->
    <add key="plenipo-local" value=".packages" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
  <!-- Prevent dependency-confusion fallback: product/platform packages must come from the
       vendored feed, while public dependencies resolve from nuget.org. -->
  <packageSourceMapping>
    <packageSource key="plenipo-local">
      <package pattern="Plenipo.*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
